# ─────────────────────────────────────────
# VitaPrime — Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────

# Supabase (get from: https://supabase.com/dashboard/project/<id>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose to client!

# Site
NEXT_PUBLIC_SITE_URL=https://vitaprime.ug

# WhatsApp (your business number in international format)
NEXT_PUBLIC_WHATSAPP_NUMBER=256700000000
